{
  "Authentication": {
    "Authority": "",
    "Audience": "api",
    "SwaggerClientId": "",
    "SwaggerClientSecret": "",
    "Scopes": ""
  },
  "OAuth": {
    "ClientId": "",
    "ClientSecret": "",
    "SigningKey": "your-256-bit-secret-key-change-this-in-production-12345",
    "TokenExpiryMinutes": 60
  },
  "TraceHeader": "X-Trace-Id",
  "Mongo": {
    "DatabaseUri": "mongodb://127.0.0.1:27017",
    "DatabaseName": "epr-register-enrol-backend"
  },
  "DetailedErrors": true,
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:o} [{Level:u4}] ({Application}/{MachineName}/{ThreadId}/{SourceContext}.{Method}) {Message}{NewLine}{Exception}"
        }
      }
    ]
  }
}
